fn main() int {
    hui disp = x11_open(400, 300, "test");
    hui runs = 0;
    while runs < 100 {
        filled_gradient(disp, 0, 0, 400, 300, 0xFFFF0000, 0xFF0000FF, 0);
        present(disp);
        hui ev = poll_event(disp);
        if ev != 0 {
            if ev == 4 { return 0; }
        }
        runs = runs + 1;
    }
    return 0;
}
